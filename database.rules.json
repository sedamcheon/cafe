{
  "rules": {
    ".read": false,
    ".write": false,
    "cafes": {
      ".read": true,
      "$cafeId": {
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
        ".validate": "!newData.exists() || newData.hasChildren(['name', 'area', 'distanceText', 'distanceMinutes', 'hours', 'features', 'menus', 'updatedAt'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 60"
        },
        "area": {
          ".validate": "newData.isString() && newData.val().length <= 80"
        },
        "locationDetail": {
          ".validate": "newData.isString() && newData.val().length <= 160"
        },
        "distanceText": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 40"
        },
        "distanceMinutes": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 60"
        },
        "hours": {
          ".validate": "newData.isString() && newData.val().length <= 80"
        },
        "features": {
          ".validate": "newData.numChildren() > 0",
          "$index": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 30"
          }
        },
        "menus": {
          ".validate": "newData.numChildren() > 0",
          "$menuId": {
            ".validate": "newData.hasChildren(['name', 'category', 'updatedAt'])",
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50"
            },
            "category": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
            },
            "price": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 20000"
            },
            "updatedAt": {
              ".validate": "newData.isString() && newData.val().matches(/^\\d{4}-\\d{2}-\\d{2}$/)"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "updatedAt": {
          ".validate": "newData.isString() && newData.val().matches(/^\\d{4}-\\d{2}-\\d{2}$/)"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "reports": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$reportId": {
        ".write": "(auth != null && root.child('admins').child(auth.uid).val() === true) || (!data.exists() && newData.exists() && newData.child('status').val() === 'pending')",
        ".validate": "newData.hasChildren(['cafeId', 'cafeName', 'menuId', 'drinkName', 'newPrice', 'status', 'createdAt', 'updatedAt'])",
        "cafeId": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "cafeName": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 60"
        },
        "menuId": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "drinkName": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50"
        },
        "currentPrice": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 20000"
        },
        "newPrice": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 20000"
        },
        "note": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "reporter": {
          ".validate": "newData.isString() && newData.val().length <= 40"
        },
        "status": {
          ".validate": "newData.isString() && newData.val().matches(/^(pending|approved|rejected)$/)"
        },
        "createdAt": {
          ".validate": "newData.isString() && newData.val().length <= 40"
        },
        "updatedAt": {
          ".validate": "newData.isString() && newData.val().length <= 40"
        },
        "reviewedAt": {
          ".validate": "newData.isString() && newData.val().length <= 40"
        },
        "reviewerUid": {
          ".validate": "newData.isString() && newData.val().length <= 128"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "admins": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
        ".validate": "newData.isBoolean()"
      }
    }
  }
}
